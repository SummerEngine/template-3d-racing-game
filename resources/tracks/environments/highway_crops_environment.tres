[gd_resource type="Resource" script_class="EnvironmentProfile" load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/track/environment_profile.gd" id="1_environment"]
[ext_resource type="Script" path="res://scripts/track/scenery_rule.gd" id="2_rule"]

[sub_resource type="Resource" id="SceneryRule_billboard"]
script = ExtResource("2_rule")
prop_id = &"billboard"
display_name = "Highway Billboards"
placement_mode = 0
sides = 2
road_edge_offset_m = 26.0
offset_jitter_m = 8.0
min_spacing_m = 85.0
max_spacing_m = 165.0
coverage_ratio_range = Vector2(0, 1)
scale_multiplier_range = Vector2(1, 1)
color_tags = PackedStringArray("bright_ads", "toy_like")
notes = "Billboards spawn on both sides and always use road-edge-relative offsets."

[sub_resource type="Resource" id="SceneryRule_crop_cluster"]
script = ExtResource("2_rule")
prop_id = &"crop_cluster"
display_name = "Crop Clusters"
placement_mode = 1
sides = 2
road_edge_offset_m = 34.0
offset_jitter_m = 10.0
min_spacing_m = 70.0
max_spacing_m = 140.0
coverage_ratio_range = Vector2(0.3, 0.5)
scale_multiplier_range = Vector2(1, 1.25)
color_tags = PackedStringArray("crop_green", "grouped")
notes = "Coverage target is 30-50 percent of each Highway/Crops section length."

[sub_resource type="Resource" id="SceneryRule_farmhouse"]
script = ExtResource("2_rule")
prop_id = &"farmhouse_fenced_area"
display_name = "Farmhouse And Fenced Animal Areas"
placement_mode = 1
sides = 2
road_edge_offset_m = 48.0
offset_jitter_m = 16.0
min_spacing_m = 180.0
max_spacing_m = 360.0
coverage_ratio_range = Vector2(0.05, 0.15)
scale_multiplier_range = Vector2(2, 3)
color_tags = PackedStringArray("playful_house_colors", "toy_like", "animals_placeholder")
notes = "Farmhouses are 2-3x car size; use placeholders and metadata hooks, not generated paid assets."

[resource]
resource_name = "HighwayCropsEnvironment"
script = ExtResource("1_environment")
display_name = "Highway/Crops"
environment_id = &"highway_crops"
environment_type = &"highway_crops"
terrain_palette = {
"crop": Color(0.36, 0.55, 0.16, 1),
"grass": Color(0.12, 0.38, 0.15, 1),
"soil": Color(0.22, 0.13, 0.08, 1)
}
prop_rules = Array[Resource]([SubResource("SceneryRule_billboard"), SubResource("SceneryRule_crop_cluster"), SubResource("SceneryRule_farmhouse")])
ambient_audio_key = &"open_road_countryside"
ambient_audio_path = ""
coverage_targets = {
"crop_cluster": Vector2(0.3, 0.5),
"farmhouse_fenced_area": Vector2(0.05, 0.15)
}
roadside_offset_rules = {
"billboard": 26.0,
"crop_cluster": 34.0,
"farmhouse_fenced_area": 48.0
}
transition_prop_rules = {
"to_industrial": "Crop clusters and farmhouses taper out; billboards shift toward industrial signage.",
"from_industrial": "Highway billboards and open sightlines return before the lap boundary."
}
notes = "Open, readable countryside environment. Billboards use both sides; crop/farmhouse coverage applies per Highway/Crops section."
