[gd_resource type="Resource" script_class="EnvironmentKitProfile" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/profiles/environment_kit_profile.gd" id="1_kit"]

[resource]
resource_name = "StormCoastEnvironmentKit"
script = ExtResource("1_kit")
kit_id = &"mountain_coastal_wet"
display_name = "Mountain Coastal Wet Kit"
environment_type = &"rainy_mountain_coastal"
style_tags = PackedStringArray("rainy_coastal", "cliffside", "wet_road", "mist", "guardrails", "power_lines")
module_scenes = PackedStringArray("res://scenes/environment/storm_coast/cliff_wall_segment.tscn", "res://scenes/environment/storm_coast/coastal_guardrail_run.tscn", "res://scenes/environment/storm_coast/power_line_run.tscn", "res://scenes/environment/storm_coast/mist_ocean_backdrop.tscn")
roadside_props = PackedStringArray("guardrail_cluster", "jump_warning_sign", "reflector_post", "power_line_pole", "service_barrier")
background_props = PackedStringArray("distant_ocean_plane", "mountain_silhouette", "low_cloud_bank", "rain_haze_card")
landmark_scenes = PackedStringArray("res://scenes/environment/storm_coast/ocean_reveal_landmark.tscn", "res://scenes/environment/storm_coast/cliffside_jump_viewpoint.tscn")
lighting_overrides = {
"fog_density": 0.085,
"reflection_probe_priority": "road_surface_and_jump",
"wetness_multiplier": 0.92
}
audio_ambience = &"storm_coast_light_rain_waves"
weather_support_tags = PackedStringArray("light_rain", "wet_road", "coastal_mist")
performance_budget = {
"background_landmarks": 4,
"hero_set_pieces": 1,
"reflection_probes": 4,
"roadside_prop_instances": 180
}
notes = "Reusable kit metadata for Storm Coast. Scene paths are placeholders for future modular assets and should remain editable through this resource."
