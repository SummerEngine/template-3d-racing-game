[gd_resource type="Resource" script_class="SetPieceProfile" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/profiles/set_piece_profile.gd" id="1_set_piece"]

[resource]
resource_name = "StormCoastCliffsideJumpSetPiece"
script = ExtResource("1_set_piece")
set_piece_id = &"storm_coast_cliffside_jump"
